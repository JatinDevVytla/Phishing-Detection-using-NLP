{
  "manifest_version": 3,
  "name": "Phishing Detector",
  "version": "1.0",
  "description": "Detects phishing emails using AI",

  "permissions": [
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "https://mail.google.com/*",
    "https://outlook.live.com/*"
  ],

  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  }
}